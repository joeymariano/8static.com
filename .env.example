# Copy this file to .env and fill in your SFTP credentials.
# .env is gitignored — do not commit it.

SFTP_HOST=sftp.8static.com
SFTP_USER=your-username
SFTP_PASS=your-password

# Remote directory on the server where _site/ contents should be mirrored.
# This host (DreamHost-style) uses a domain-named directory at /home/<user>/<domain>/
# rather than the cPanel /public_html convention.
SFTP_REMOTE_PATH=/home/animalstyle/8static.com

# Optional: SFTP port (defaults to 22)
# SFTP_PORT=22
